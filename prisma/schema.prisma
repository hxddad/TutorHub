// This is your Prisma schema file,

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  CANCELLED
  COMPLETED
}

model User {
  id        String   @id @default(uuid())
  fullName  String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  // optional profile fields
  bio       String?
  avatar    String?
  subjects  String?  // comma-separated list or JSON if needed

  // relations
  courses   Course[]       // courses taught (tutor)
  enrollments Enrollment[] // courses enrolled (student)
  submissions     Submission[]
  progresses      Progress[]

  messagesSent     Message[] @relation("MessagesSent")
  messagesReceived Message[] @relation("MessagesReceived")

  // study plans
  studyPlans StudyPlan[]
}

// Direct user-to-user messaging (stored in PostgreSQL, retrieved via Prisma).
model Message {
  id         String   @id @default(uuid())
  senderId   String // who sent (maps to your "SendId" concept)
  receiverId String
  content    String   @db.Text
  createdAt  DateTime @default(now()) // message timestamp
  isRead     Boolean  @default(false)

  sender   User @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@index([receiverId, isRead])
}

model Course {
  id          Int      @id @default(autoincrement())
  title       String
  subject     String
  description String?
  tutor       User     @relation(fields: [tutorId], references: [id])
  tutorId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // new fields for browsing/enrollment
  isPublished Boolean  @default(false)
  capacity    Int?
  price       Float?
  level       String?   // e.g. "Beginner", "Intermediate", "Advanced"
  tags        String?   // comma-separated; or use Json if preferred
  schedule    Json?     // structured schedule (timeslots) stored as JSON
  averageRating Float?  @default(0)

  // relations
  enrollments Enrollment[]
  assignments Assignment[]
  progresses   Progress[]
  tasks Task[] 
}

model Enrollment {
  id         Int      @id @default(autoincrement())
  student    User     @relation(fields: [studentId], references: [id])
  studentId  String
  course     Course   @relation(fields: [courseId], references: [id])
  courseId   Int
  status     EnrollmentStatus @default(PENDING)
  enrolledAt DateTime @default(now())

  @@unique([studentId, courseId])
}

model Assignment {
  id          Int      @id @default(autoincrement())
  course      Course   @relation(fields: [courseId], references: [id])
  courseId    Int
  title       String
  description String?
  dueDate     DateTime?
  createdAt   DateTime @default(now())

  submissions Submission[]
}

model Submission {
  id           Int      @id @default(autoincrement())
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  assignmentId Int
  student      User     @relation(fields: [studentId], references: [id])
  studentId    String
  content      String?
  grade        Float?
  feedback     String?
  reviewedAt   DateTime?
  submittedAt  DateTime @default(now())

  @@unique([assignmentId, studentId])
}

model Progress {
  id            Int      @id @default(autoincrement())
  student       User     @relation(fields: [studentId], references: [id])
  studentId     String
  course        Course   @relation(fields: [courseId], references: [id])
  courseId      Int
  progressPercent Int    @default(0)
  lastUpdated   DateTime @updatedAt
  notes         String?
}

model StudyPlan {
  id         Int      @id @default(autoincrement())
  studentId  String
  student    User     @relation(fields: [studentId], references: [id])
  tasks      Task[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Task {
  id          Int       @id @default(autoincrement())
  studyPlanId Int
  studyPlan   StudyPlan @relation(fields: [studyPlanId], references: [id])
  courseId    Int       // add this
  course      Course    @relation(fields: [courseId], references: [id])
  title       String
  dueDate     DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}