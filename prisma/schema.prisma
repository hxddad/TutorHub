// This is your Prisma schema file,

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  fullName  String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  courses   Course[]
}

model Course {
  id          Int      @id @default(autoincrement())
  title       String
  subject     String
  description String?
  tutor       User     @relation(fields: [tutorId], references: [id])
  tutorId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
